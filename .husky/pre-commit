#!/bin/sh
set -e

# Block .vscode/settings.json commits (AI tools sometimes modify this)
if [ -n "$(git diff --cached --name-only -- .vscode/settings.json)" ]; then
  echo "Error: Attempting to commit changes to .vscode/settings.json"
  echo "Please unstage: git reset HEAD .vscode/settings.json"
  exit 1
fi

# Run typecheck + lint + tests in parallel
npm run parallel-check:quiet

# Check formatting on staged files only (fast: skips unchanged files)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR -- '*.ts' '*.tsx' '*.js' '*.jsx')
if [ -n "$STAGED_FILES" ]; then
  if ! echo "$STAGED_FILES" | xargs npx prettier --check; then
    echo ""
    echo "Some files are not properly formatted."
    echo "Run 'npm run format:write' and stage the changes, then commit again."
    exit 1
  fi
fi
